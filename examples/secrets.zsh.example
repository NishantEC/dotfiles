# Local secrets — copy to ~/.config/zsh/secrets.zsh and fill in.
#
# Once present, ~/.zshrc will source it automatically.
#
# IMPORTANT:
#   - This file should be mode 600: chmod 600 ~/.config/zsh/secrets.zsh
#   - NEVER commit this file or its contents to a public repo.
#   - For higher-stakes secrets, prefer a real secret store (1Password CLI,
#     keychain, age/sops) over plaintext exports.

# --- GitHub PAT (used by npm to install private packages) -----------
# export NPM_AUTH_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- AI provider API keys -------------------------------------------
# export OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"
# export ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"

# --- AWS / cloud credentials ----------------------------------------
# (Prefer `aws configure` and ~/.aws/credentials over env vars where possible.)
# export AWS_ACCESS_KEY_ID="..."
# export AWS_SECRET_ACCESS_KEY="..."

# --- Misc service tokens --------------------------------------------
# export LINEAR_API_KEY="..."
# export STRIPE_SECRET_KEY="sk_test_..."
